# GitLab plugin configuration
#
# Copy this file to gitlab.env and uncomment the variables you need:
#   cp gitlab.env.example gitlab.env
#
# Supports multiple instances. Use GITLAB_{NAME}_TOKEN pattern
# for each instance, or GITLAB_TOKEN for a single instance.

# --- Single instance ---
#GITLAB_URL=https://gitlab.com
#GITLAB_TOKEN=your-personal-access-token

# --- Multiple instances ---
# Configure each instance with a name:
#
#GITLAB_PUBLIC_URL=https://gitlab.com
#GITLAB_PUBLIC_TOKEN=your-public-gitlab-token
#
#GITLAB_INTERNAL_URL=https://gitlab.internal.example.com
#GITLAB_INTERNAL_TOKEN=your-internal-gitlab-token

# SSL verification (optional, default: true)
# Set to false for self-signed certificates
#GITLAB_SSL_VERIFY=true
# Per-instance: GITLAB_INTERNAL_SSL_VERIFY=false
