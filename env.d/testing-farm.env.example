# Testing Farm API token (required)
# Request from: https://docs.testing-farm.io/Testing%20Farm/0.1/onboarding.html
TESTING_FARM_API_TOKEN=

# Testing Farm API URL (optional, defaults to public ranch)
# TF_API_URL=https://api.testing-farm.io

# Path to SSH public key for reservations (optional, auto-detected from ~/.ssh/)
# TF_SSH_KEY_PATH=/home/user/.ssh/id_ed25519.pub
