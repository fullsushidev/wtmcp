# Jira plugin configuration
#
# Copy this file to jira.env and uncomment the variables you need:
#   cp jira.env.example jira.env

# Jira instance URL (required)
#JIRA_URL=https://your-instance.atlassian.net

# Auth type: auto, cloud, server-token, server-kerberos
# "auto" picks the right one based on available credentials.
#JIRA_AUTH_TYPE=auto

# --- Cloud (Atlassian Cloud) ---
# Your Atlassian account email
#JIRA_EMAIL=you@example.com
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
#JIRA_TOKEN=your-api-token

# --- Server/DC (bearer token) ---
# Set JIRA_AUTH_TYPE=server-token and use a Personal Access Token
#JIRA_TOKEN=your-personal-access-token

# --- Server/DC (Kerberos) ---
# Set JIRA_AUTH_TYPE=server-kerberos
# Kerberos auth uses your existing ticket (kinit)
