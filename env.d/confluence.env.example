# Confluence plugin configuration
#
# Copy this file to confluence.env and uncomment the variables you need:
#   cp confluence.env.example confluence.env

# Confluence instance URL (required)
#CONFLUENCE_URL=https://your-instance.atlassian.net/wiki

# Auth type: auto, cloud, server-token, server-kerberos
#CONFLUENCE_AUTH_TYPE=auto

# --- Cloud (Atlassian Cloud) ---
#CONFLUENCE_EMAIL=you@example.com
# API token from https://id.atlassian.com/manage-profile/security/api-tokens
#CONFLUENCE_TOKEN=your-api-token

# --- Server/DC (bearer token) ---
# Set CONFLUENCE_AUTH_TYPE=server-token
#CONFLUENCE_TOKEN=your-personal-access-token

# --- Server/DC (Kerberos) ---
# Set CONFLUENCE_AUTH_TYPE=server-kerberos
# Kerberos auth uses your existing ticket (kinit)

# SSL verification (optional, default: true)
#CONFLUENCE_SSL_VERIFY=true
