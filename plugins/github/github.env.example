# GitHub personal access token
# Create at: https://github.com/settings/tokens
#
# Classic PAT scopes needed: repo, read:org, notifications
# Fine-grained PAT: Issues (read), Pull Requests (read), Metadata (read)
#   Note: notifications tool requires a classic PAT
#
# DO NOT commit this file to version control.
GITHUB_TOKEN=your_token_here

# GitHub API URL (optional — only for GitHub Enterprise)
# For github.com, leave this commented out or remove it.
# GITHUB_URL=https://github.example.com/api/v3
